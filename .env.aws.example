# Django
SECRET_KEY=
DEBUG=False
ALLOWED_HOSTS=TU_IP_PUBLICA_EC2,localhost,127.0.0.1

# Base de datos PostgreSQL dentro de Docker
POSTGRES_DB=horarium
POSTGRES_USER=horarium
POSTGRES_PASSWORD=
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis y Celery dentro de Docker
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Duracion de los tokens JWT
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# Sustituir TU_IP_PUBLICA_EC2 por la IP publica de la instancia.
CORS_ALLOWED_ORIGINS=http://TU_IP_PUBLICA_EC2
FRONTEND_URL=http://TU_IP_PUBLICA_EC2

# Email
# Para demo se puede dejar en consola. Para envio real, cambiar a SMTP.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Horarium <no-reply@iespoligonosur.org>