# Django
SECRET_KEY=cambia-esta-clave-en-produccion-usa-una-larga-y-aleatoria
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos PostgreSQL
POSTGRES_DB=horarium
POSTGRES_USER=horarium
POSTGRES_PASSWORD=horarium123
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis y Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Duracion de los tokens JWT
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# Origen permitido para llamadas desde Angular
CORS_ALLOWED_ORIGINS=http://localhost:4200

# URL publica que se mete en los enlaces de recuperacion de contraseña
FRONTEND_URL=http://localhost:4200

# Email
# En desarrollo los correos salen por consola. En produccion se cambia a SMTP.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Horarium <no-reply@iespoligonosur.org>
